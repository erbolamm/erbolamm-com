{
  "rules": {
    ".read": "auth != null",
    "presence": {
      "$uid": {
        ".write": "$uid === auth.uid",
        "lastActive": { ".validate": "newData.isNumber()" }
      }
    },
    "inbox": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "$msgId": {
          ".write": "auth != null",
          ".validate": "newData.hasChild('fromUid') && newData.child('fromUid').val() === auth.uid"
        }
      }
    },
    "nodes": {
      ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || !data.exists())",
      "$nodeId": {
        ".write": "auth != null && (data.child('authorUid').val() === auth.uid || !data.exists())"
      }
    },
    "bot-config": {
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "admins": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
